# THE ANTS — AI chat configuration
# Copy this file to .env and fill in ANTHROPIC_API_KEY.
# Everything else has production-ready defaults.

# === REQUIRED ===
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === OPTIONAL ===

# Model ID. Defaults to the most capable current model.
# Options: claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-7

# Reasoning effort. low | medium | high | xhigh | max
CLAUDE_EFFORT=high

# Max tokens per response.
CLAUDE_MAX_TOKENS=16000

# Maximum file upload size in MB.
MAX_UPLOAD_MB=25

# Requests per minute per IP.
RATE_LIMIT_PER_MIN=20

# Flask secret key (auto-generated if empty, but set it in production).
FLASK_SECRET_KEY=

# Enable debug mode. Never enable in production.
FLASK_DEBUG=0

# === FEATURE FLAGS (all enabled by default) ===
ENABLE_WEB_SEARCH=1
ENABLE_WEB_FETCH=1
ENABLE_CODE_EXECUTION=1
ENABLE_FILE_UPLOAD=1
ENABLE_THINKING=1
ENABLE_PROMPT_CACHING=1
